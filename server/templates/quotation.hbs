<!DOCTYPE html>
<html>
<head>
    <style>
        /* --- GLOBAL STYLES --- */
        body { font-family: Arial, sans-serif; margin: 0; padding: 0; color: #333; }
        .page { 
            width: 100%; height: 100vh; position: relative; 
            padding: 40px; box-sizing: border-box; 
            background: white;
        }
        .page-break { page-break-after: always; }
        
        /* HEADERS & TEXT */
        .brand-color { color: #2E7D32; } /* Meetra Green */
        .title-large { font-size: 32px; font-weight: bold; color: #2E7D32; margin-bottom: 10px; }
        .title-medium { font-size: 20px; font-weight: bold; color: #2E7D32; margin-top: 20px; }
        
        /* TABLES (Matches your Bill of Materials) */
        table { width: 100%; border-collapse: collapse; font-size: 12px; margin-top: 15px; }
        th { background-color: #2E7D32; color: white; padding: 10px; border: 1px solid #ccc; }
        td { border: 1px solid #ccc; padding: 8px; text-align: left; vertical-align: top; }
        .center { text-align: center; }

        /* IMAGES */
        img.full-width { width: 100%; height: auto; display: block; margin: 20px auto; }
        
        /* FOOTER */
        .footer { 
            position: absolute; bottom: 20px; left: 40px; right: 40px; 
            font-size: 10px; color: #777; border-top: 1px solid #eee; padding-top: 10px; 
        }
    </style>
</head>
<body>

    <div class="page">
        <img src="http://localhost:5000/logo.png" style="width: 200px;">
        <h3 style="color: #666;">Renewable • Reasonable • Reliable</h3>
        
        <div style="margin-top: 150px;">
            <h1 class="title-large" style="border-bottom: 4px solid #2E7D32; display: inline-block;">Techno - Commercial Proposal</h1>
            <h2>Prepared For: <span style="color:black">{{customerName}}</span></h2>
            <h3>{{location}}</h3>
        </div>

        <div style="position: absolute; bottom: 50px;">
            <p><strong>Contact Us:</strong> +91 7359227562 | meetragreen@gmail.com</p>
            <p>907, Raiya Raj Complex, Jetpur - 360370</p>
        </div>
    </div>
    <div class="page-break"></div>

    <div class="page">
        <h2 class="title-medium">Project Details</h2>
        <table>
            <tr><td style="width: 30%;"><strong>Quotation No:</strong></td><td>MGE-C-2502</td></tr>
            <tr><td><strong>Date:</strong></td><td>{{date}}</td></tr> <tr><td><strong>Customer Name:</strong></td><td>{{customerName}}</td></tr>
            <tr><td><strong>Plant Capacity:</strong></td><td>{{plantCapacity}} kW</td></tr>
            <tr><td><strong>Location:</strong></td><td>{{location}}</td></tr>
        </table>
        
        <div style="margin-top: 50px; padding: 20px; background: #f9f9f9; border-left: 5px solid #2E7D32;">
            <p><strong>Submitted To:</strong> {{customerName}}</p>
            <p>Submitted in fulfilment of the requirement stated for Solar Power Project.</p>
        </div>
    </div>
    <div class="page-break"></div>

    <div class="page">
        <h2 class="title-medium">We Are Associated With</h2>
        <p>Our goal is to help you harness the power of solar energy efficiently.</p>
        <img src="http://localhost:5000/approvals.png" class="full-width" style="max-width: 80%;">
    </div>
    <div class="page-break"></div>

    <div class="page">
        <h2 class="title-medium">Solar Working Diagram</h2>
        <img src="http://localhost:5000/diagram.png" class="full-width">
    </div>
    <div class="page-break"></div>

    <div class="page">
        <h2 class="title-medium">Bill of Materials / Quantity Part (I)</h2>
        <table>
            <thead>
                <tr>
                    <th>Material</th>
                    <th>Specification</th>
                    <th>Make</th>
                    <th class="center">Unit</th>
                    <th class="center">Qty</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><strong>PV Modules</strong></td>
                    <td>560 Wp ALMM LISTED<br>TOPCON Tech</td>
                    <td>RAAJRATNA</td>
                    <td class="center">Nos</td>
                    <td class="center">17</td>
                </tr>
                <tr>
                    <td><strong>Inverter</strong></td>
                    <td>AC Capacity 10kW<br>98.8% Efficiency</td>
                    <td>X Watt / UTL</td>
                    <td class="center">Nos</td>
                    <td class="center">1</td>
                </tr>
                <tr>
                    <td><strong>Structure</strong></td>
                    <td>Hot Dip Galvanized<br>150 kmph Wind Speed</td>
                    <td>Hindustar</td>
                    <td class="center">Job</td>
                    <td class="center">370 kg</td>
                </tr>
                 <tr>
                    <td><strong>AC/DC Box</strong></td>
                    <td>IP65 Protection</td>
                    <td>HAVELLS</td>
                    <td class="center">Nos</td>
                    <td class="center">1</td>
                </tr>
            </tbody>
        </table>
    </div>
    <div class="page-break"></div>

    <div class="page">
        <h2 class="title-medium">Bill of Materials / Quantity Part (II)</h2>
        <img src="http://localhost:5000/house.png" style="width: 80%; margin: 0 auto; display:block;">
        
        <table>
            <thead>
                <tr>
                    <th>Material</th>
                    <th>Specification</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><strong>Earthing</strong></td>
                    <td>Chemical Earthing Pit as per IS 3043</td>
                </tr>
                <tr>
                    <td><strong>Cabling</strong></td>
                    <td>Polycab DC/AC Cables</td>
                </tr>
                <tr>
                    <td><strong>Approvals</strong></td>
                    <td>GEDA, CEIG, Net Metering</td>
                </tr>
            </tbody>
        </table>
    </div>
    <div class="page-break"></div>

    <div class="page">
        <h2 class="title-medium">Commercial Proposal</h2>
        <table style="margin-top: 30px;">
            <thead>
                <tr>
                    <th>Description</th>
                    <th>Amount (INR)</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>System Cost ({{plantCapacity}} kW)</td>
                    <td>₹ {{systemCost}}</td>
                </tr>
                <tr>
                    <td>GST (8.90%)</td>
                    <td>₹ {{gstAmount}}</td>
                </tr>
                <tr>
                    <td>Structure Cost</td>
                    <td>₹ 38,500.00</td>
                </tr>
                <tr style="background: #e8f5e9; font-weight: bold; font-size: 14px;">
                    <td>NET PAYABLE AMOUNT</td>
                    <td>₹ {{totalAmount}}</td>
                </tr>
            </tbody>
        </table>
        
        <p style="margin-top: 40px; font-size: 12px; color: #555;">
            * GEDA Registration charges extra at actuals.<br>
            * Discom Net Meter charges are extra.
        </p>
    </div>
    <div class="page-break"></div>

    <div class="page">
        <h2 class="title-medium">Warranties & Guaranties</h2>
        <ul>
            <li><strong>PV Module:</strong> 30 Years Performance Warranty.</li>
            <li><strong>Inverter:</strong> 8 Years Product Replacement Warranty.</li>
            <li><strong>Service:</strong> 1 Year Technical Maintenance Included.</li>
        </ul>

        <h2 class="title-medium" style="margin-top: 40px;">Terms & Conditions</h2>
        <ol style="font-size: 13px; line-height: 1.6;">
            <li>Charges for maintenance for ONE YEAR are included.</li>
            <li>Price subject to change with volatile market trends. Validity 10 Days.</li>
            <li>Order cancellation will not be granted.</li>
            <li>Regular cleaning of panels is in Client's Scope.</li>
            <li>Delays in payments may extend completion period.</li>
        </ol>
    </div>
    <div class="page-break"></div>

    <div class="page">
        <h2 class="title-medium">Scope of Works</h2>
        <ul>
            <li>Site survey, design, and engineering.</li>
            <li>Supply and installation of Modules & Inverters.</li>
            <li>Net Metering and Agency Approvals.</li>
        </ul>

        <img src="http://localhost:5000/robot.png" style="width: 200px; display: block; margin: 30px auto;">

        <div style="border: 2px dashed #2E7D32; padding: 20px; border-radius: 10px;">
            <strong>Bank Details:</strong><br>
            Name: Meetra Green Energy<br>
            Bank: Bank of Baroda<br>
            Account: 80400200003267<br>
            IFSC: BARBOVJJETP
        </div>
    </div>
    <div class="page-break"></div>

    <div class="page" style="text-align: center; padding-top: 200px;">
        <h1 class="brand-color">Thank You!</h1>
        <p>We look forward to powering your world.</p>
        
        <div style="margin-top: 50px;">
            <strong>Connect With Us</strong><br>
            +91 7359227562<br>
            meetragreen@gmail.com
        </div>
    </div>

</body>
</html>